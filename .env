# AWS SSO Configuration Template
# ================================
# Copy this file to .env.local and fill in your organization's AWS SSO values.
# DO NOT commit .env.local to version control - it contains sensitive information.
#
# For more details and setup instructions, see the README.md file.

# AWS SSO Start URL
# The authentication endpoint for your organization's AWS SSO instance.
# Find this in your AWS console under AWS SSO > Settings > Authentication
# Example: https://your-org.awsapps.com/start
awsStartURL="https://your-org.awsapps.com/start"

# AWS SSO Session Name
# An internal identifier for your AWS SSO session configuration (no spaces).
# Used in local AWS CLI configuration, recommend using org-session format.
# Example: my-org-session
awsDefaultSession="my-org-session"

# Default AWS Profile Name
# The name of your organization's root/primary AWS account in the CLI profile.
# This is the account that has access to Organizations API to list all accounts.
# Recommendation: Use your organization name as the profile name.
# Example: my-organization
awsDefaultProfile="my-organization"

# Organization Root Account ID
# The AWS account ID of your organization's root/primary account (12 digits).
# Used to establish the initial AWS Organizations connection.
# Example: 111111111111
awsDefaultProfileAccountId="111111111111"

# Default IAM Role Name
# The SSO role name to use by default when accessing AWS accounts.
# This role must be assigned to your user in AWS SSO and present in all target accounts.
# Common values: Admin, PowerUser, Developer, DevOps-Tech
# Example: Admin
awsDefaultSSORole="Admin"

# AWS Region
# The default AWS region for CLI operations and SSO authentication.
# Should match the region where your AWS SSO instance is configured.
# Valid examples: us-east-1, us-east-2, eu-west-1, ap-southeast-1
# Example: us-east-1
awsDefaultRegion="us-east-1"
